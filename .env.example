# =====================================================================
# Plantilla de variables de entorno (público)
# Copiar a `.env` y rellenar con valores reales (los valores reales
# viven en `../_local/credenciales.env` — NO se comitean).
# =====================================================================

# ---------- Backend FastAPI ----------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=

# ---------- Base de datos (Supabase Postgres) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# DB directa (usar solo si el backend habla Postgres por TCP)
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/postgres

# ---------- Cache / Broker (Redis) ----------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- Almacenamiento (MinIO / S3) ----------
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_USE_SSL=true

# ---------- Frontend (Angular) ----------
NG_API_BASE_URL=http://localhost:8000
NG_SUPABASE_URL=
NG_SUPABASE_ANON_KEY=
